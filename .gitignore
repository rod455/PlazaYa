#     na Play Store. Faça backup em local seguro!
# ══════════════════════════════════════════════════════════════

# Keystores (qualquer localização, qualquer extensão)
*.keystore
*.jks
*.pk8
*.pem
**/*.keystore
**/*.jks
**/release.keystore
**/upload.keystore
**/debug.keystore

# Keystore properties (contém senhas da keystore)
**/keystore.properties
**/key.properties
**/signing.properties
**/release-signing.properties

# Google Services (Firebase credentials)
**/google-services.json
**/GoogleService-Info.plist

# Play Store service account key
**/pc-api-key.json
**/play-store-key.json
**/service-account*.json

# Expo/EAS credentials
credentials.json
credentials/
eas-credentials/

# Upload certificate
upload_certificate.pem
**/upload_certificate.pem

# ─── Variáveis de ambiente — NUNCA subir! ────────────────────
.env
.env.*
.env.local
.env.production
.env.staging
!.env.example

# ─── iOS ─────────────────────────────────────────────────────
ios/build/
ios/Pods/
*.p12
*.mobileprovision
*.cer

# ─── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────
npm-debug.log*
yarn-error.log*
*.log

# ─── Build outputs ───────────────────────────────────────────
*.aab
*.apk
