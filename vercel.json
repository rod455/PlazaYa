{
  "version": 2,
  "builds": [
    {
      "src": "site/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/privacidad",
      "dest": "/site/privacidad.html"
    },
    {
      "src": "/eliminacion-de-datos",
      "dest": "/site/eliminacion-de-datos.html"
    },
    {
      "src": "/",
      "dest": "/site/index.html"
    }
  ]
}
