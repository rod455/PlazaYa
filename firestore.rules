rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios — cada um acessa só o próprio doc
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Também permite escrita anônima (sem auth) para salvar token FCM
      allow create: if true;
      allow update: if true;
    }

    // Questões — somente leitura
    match /questoes/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Notícias de concursos (feeds RSS)
    match /noticias_concursos/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Concursos coletados via scraping
    match /bancas_concursos/{id} {
      allow read: if true;
      allow write: if false;
    }

    // PDFs de provas e gabaritos
    match /materiais_provas/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Stats do sistema
    match /stats/{doc} {
      allow read: if true;
      allow write: if false;
    }
  }
}
